NODE_ENV=development
PORT=3333
HOST=localhost
APP_KEY=
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=fauxdetect

# Redis (for Bull Queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Taggun OCR API (https://www.taggun.io)
TAGGUN_API_KEY=

# Email (SMTP — Mailpit for development: http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@fauxdetect.com
